# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/velgo_agri
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/velgo_agri?retryWrites=true&w=majority

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-key-here-change-in-production
JWT_EXPIRATION_HOURS=24

# Admin Default Credentials (for initial setup)
ADMIN_EMAIL=admin@velgo.com
ADMIN_PASSWORD=admin123
